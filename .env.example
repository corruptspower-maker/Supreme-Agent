# GitHub Copilot OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
COPILOT_TOKEN=

# LM Studio
LMSTUDIO_ENDPOINT=http://localhost:1234/v1
LM_STUDIO_API_KEY=
LM_STUDIO_BASE_URL=http://localhost:1234/v1
# Vision model loaded in LM Studio (Qwen 3.5 with vision capability)
LM_STUDIO_VISION_MODEL=omnicoder-qwen3.5-9b-claude-4.6-opus-uncensored-v2
LM_STUDIO_TIMEOUT=120

# MCP Server
MCP_PORT=8766

# Optional: email config
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Semantic Memory (optional)
SEMANTIC_MEMORY_ENABLED=true
CHROMA_DB_PATH=./data/chroma
